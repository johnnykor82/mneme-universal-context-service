{
  "mcpServers": {
    "mneme": {
      "command": "/path/to/mneme-universal-context-service/.venv/bin/python",
      "args": [
        "-m",
        "mneme_service.cli",
        "mcp",
        "--base-url",
        "http://127.0.0.1:8767"
      ],
      "env": {
        "PYTHONPATH": "/path/to/mneme-universal-context-service",
        "MNEME_AUTH_TOKEN": "<mneme-auth-token>"
      }
    }
  }
}
